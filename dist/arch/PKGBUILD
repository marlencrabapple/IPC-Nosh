# Maintainer: Ian Bradley <crabapp@softsrv.net>
_package="IPC::Nosh"
_repo="${_package//::/-}"
pkgname="${_repo,,*}"
pkgver=0.01.g3947a60
_dist="${_repo-${pkgver/%.r*/}}"
pkgrel=1
pkgdesc="IPC::Nosh..."
arch=(any)
license=('Artistic-1.0-Perl' 'GPL-1.0-or-later')
depends=('perl' 'perl-const-fast' 'perl-object-pad' 'perl-ipc-run3')
makedepends=('perl-module-build-tiny' 'perl-app-fatpacker' 'cpanminus')
options=('!emptydirs' 'staticlibs')
url="https://git.sr.ht/~crabapp/IPC-Nosh"
_commit=3947a607f22be66036db32c4dd0252014c27ba94
source=("git+$url#commit=$_commit")
sha512sums=('fc66d87c7d4942c3689dab1b52713cec37671323171f8de379f3425bc732de1c6c2d90de8fdce22758baa35ed548a327480da5eb4ecdb1f82578fb750efd3bbe')
b2sums=('33f1998df7ff999c823aa2735f07b451a134e249711e2974398374e560ea0b04ce4d3e8e26309a4b13dfc10f8bb14c496845e7aac0ab179d5a93e9d1ecce05bf')

pkgver() {
    cd "$srcdir/$_repo"
    _pkgver="$(git describe --always)"
    printf "%s.g%s" "${pkgver%%.g*}" "${_pkgver//-/.}"
}

prepare() {
    unset PERL5LIB PERL_MM_OPT PERL_MB_OPT PERL_LOCAL_LIB_ROOT
}

build() {
    cd "$srcdir/$_repo"

    perl Build.PL
    ./Build build
}

# check() {
#     cd "$srcdir/$_repo"
#     ./Build test
# }

package() {
    cd "$srcdir/$_repo"

    ./Build install \
        --destdir="$pkgdir" \
        --installdirs=vendor \
        --install_base=/usr \
        --prefix=/usr \
        --verbose
}
